# Mangrove Publication Studio — Environment Variables
# Copy to .env and fill in MANGROVE_DB_PASSWORD

MANGROVE_DB_HOST=pg-mangrove-n8n.postgres.database.azure.com
MANGROVE_DB_PORT=5432
MANGROVE_DB_NAME=mangrove_workbench
MANGROVE_DB_USER=n8nadmin
MANGROVE_DB_PASSWORD=your_password_here

